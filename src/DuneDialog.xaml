<Window x:Class="MessageBox.DuneDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Alert"
        Height="280" Width="460"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        WindowStyle="None"
        Background="Transparent">

    <Border x:Name="OuterBorder" Margin="10" CornerRadius="4" BorderThickness="1"
            BorderBrush="#FF4ECDC4" Padding="0"
            Background="#CC0A0F1A">
        <Border.Effect>
            <DropShadowEffect BlurRadius="32" ShadowDepth="0" Color="#FF00FFFF" Opacity="0.25"/>
        </Border.Effect>

        <Grid Height="276" VerticalAlignment="Top">

            <Rectangle x:Name="TopBar" Height="2" VerticalAlignment="Top"
                       Fill="#FF4ECDC4" Margin="0,0,0,0"/>

            <StackPanel VerticalAlignment="Center" Height="236">

                <TextBlock x:Name="TitleText"
                           Text="ALERT"
                           FontSize="34"
                           FontFamily="pack://application:,,,/MessageBox;component/res/fonts/#Dream MMA"
                           Foreground="#FF4ECDC4"
                           HorizontalAlignment="Center"
                           Margin="0,8,0,14">
                    <TextBlock.Effect>
                        <DropShadowEffect BlurRadius="10" ShadowDepth="0"
                                          Color="#FF4ECDC4" Opacity="0.8"/>
                    </TextBlock.Effect>
                </TextBlock>

                <Border x:Name="MessageBorder" CornerRadius="2" Margin="30,10,30,0"
                        Background="#1A4ECDC4" BorderBrush="#664ECDC4" BorderThickness="1">
                    <TextBlock x:Name="MessageText"
                               Text=""
                               FontSize="13"
                               FontFamily="pack://application:,,,/MessageBox;component/res/fonts/#White Rabbit"
                               Foreground="#FFCCE8E6"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               MaxWidth="380"
                               Height="76"
                               Padding="18,12"/>
                </Border>

                <Button x:Name="btnOk"
                        Width="100" Height="28" Content="CONFIRM"
                        Background="#1A4ECDC4"
                        Foreground="#FF4ECDC4"
                        FontWeight="Normal"
                        BorderBrush="#FF4ECDC4" BorderThickness="1"
                        Cursor="Hand"
                        FontFamily="pack://application:,,,/MessageBox;component/res/fonts/#White Rabbit"
                        FontSize="12"
                        HorizontalAlignment="Center"
                        Margin="0,28,0,0"
                        Click="OK_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="border"
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="2">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="border" Property="Background" Value="#334ECDC4"/>
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter TargetName="border" Property="Background" Value="#554ECDC4"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>

            </StackPanel>

            <Rectangle x:Name="BottomBar" Height="2" VerticalAlignment="Bottom"
                       Fill="#FF4ECDC4" Margin="0,0,0,0"/>
        </Grid>
    </Border>
</Window>
